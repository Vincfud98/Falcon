# Normaliza line endings entre PCs Windows / Mac / Linux.
# Sem isso, todo arquivo abre como "modificado" no git de máquinas
# diferentes só por causa de CRLF vs LF.

* text=auto eol=lf

# Binários — não tocar
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.webp  binary
*.ico   binary
*.pdf   binary
*.zip   binary
*.woff  binary
*.woff2 binary
*.ttf   binary
*.otf   binary
